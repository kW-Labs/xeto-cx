//
// Example project + OPR — demonstrates the requirement model, the three
// verification planes, and the EBCx continuation: OPR -> CFR transition,
// ongoing commissioning, verification results, an owner-accepted
// variance, and the Systems Manual as an index of living records.
// Values are illustrative.
//

@ex-project: CxProject {
  dis: "Example Office Building Cx"
  siteRef: @ex-site
  designPhase
}

@ex-site: Dict {
  dis: "Example Office Building"
}

@ex-team-cxp: CxTeamMember {
  cxProjectRef: @ex-project
  name: "Example CxP Lead"
  org: "Example Commissioning Provider"
  cxpRole
}

@ex-opr: Opr {
  dis: "Example OPR v1.0"
  cxProjectRef: @ex-project
  siteRef: @ex-site
  version: "1.0"
  docSignedOff
  narrative: "The owner requires an energy-efficient, comfortable, maintainable facility commissioned per ASHRAE Guideline 0."
}

// ── Conformance-plane requirements — machine-checked via fits() ──────────

@ex-req-ahu-hr: Requirement {
  dis: "AHU heat recovery"
  docRef: @ex-opr
  reqId: "OPR-3.1.1"
  category: "energy"
  narrative: "All air handling units serving more than 5,000 cfm outdoor air shall include exhaust air heat recovery."
  conformancePlane
  reqRequired
  targetSpec: "ph::Ahu"
}

@ex-req-ahu-hr-c: SpecConstraint {
  requirementRef: @ex-req-ahu-hr
  slot: "heatRecovery"
  requiredMarker: "heatRecovery"
}

@ex-req-chw-dt: Requirement {
  dis: "Chilled water design delta-T"
  docRef: @ex-opr
  reqId: "OPR-3.2.1"
  category: "energy"
  narrative: "Chilled water systems shall be designed for a minimum 12 degF delta-T at design load."
  conformancePlane
  reqRequired
  targetSpec: "ph::Chiller"
}

@ex-req-chw-dt-c: SpecConstraint {
  requirementRef: @ex-req-chw-dt
  slot: "designDeltaT"
  minVal: 12
  unit: "Δ°F"
}

// ── Performance-plane requirements — evaluated against telemetry ─────────

@ex-req-space-temp: Requirement {
  dis: "Space temperature compliance"
  docRef: @ex-opr
  reqId: "OPR-4.1.1"
  category: "comfort"
  narrative: "Occupied spaces shall maintain 70-74 degF during occupied hours at 95 percent adherence."
  performancePlane
  reqRequired
  spaceSpec: "ph::Space"
}

@ex-req-space-temp-c: PerformanceCriterion {
  requirementRef: @ex-req-space-temp
  pointSpec: "ph::Point"
  minVal: 70
  maxVal: 74
  unit: "°F"
  adherenceTarget: 95
  evalSpan: "occupied hours, 30day rolling"
  autoMode
}

// ── Room-matrix requirements — per-space-type, per-mode criteria ─────────
// The shape of a room-by-room OPR acceptance matrix: one requirement per
// space type per quantity, one PerformanceCriterion per occupancy mode,
// each carrying setpoint band + tolerance + adherence, with the governing
// standard cited on the requirement.

@ex-req-patient-temp: Requirement {
  dis: "Patient room temperature"
  docRef: @ex-opr
  reqId: "OPR-4.2.1"
  category: "comfort"
  oprHealthIeq
  keyOpr
  narrative: "Patient rooms shall maintain 70-75 degF while occupied and 65-78 degF while unoccupied, within 1 degF tolerance, at the stated adherence."
  citation: "ASHRAE 170-2013 Table 7-1"
  performancePlane
  reqRequired
  spaceSpec: "ph::Space"
  spaceTypeKey: "patientRoom"
}

@ex-req-patient-temp-occ: PerformanceCriterion {
  requirementRef: @ex-req-patient-temp
  pointSpec: "ph::Point"
  occupiedMode
  minVal: 70
  maxVal: 75
  tolerance: 1
  unit: "°F"
  adherenceTarget: 95
  autoMode
}

@ex-req-patient-temp-unocc: PerformanceCriterion {
  requirementRef: @ex-req-patient-temp
  pointSpec: "ph::Point"
  unoccupiedMode
  minVal: 65
  maxVal: 78
  tolerance: 1
  unit: "°F"
  adherenceTarget: 90
  autoMode
}

@ex-req-aii-pressure: Requirement {
  dis: "AII room pressurization"
  docRef: @ex-opr
  reqId: "OPR-4.2.2"
  category: "iaq"
  oprHealthIeq
  keyOpr
  narrative: "Airborne infection isolation rooms shall maintain negative pressure of 0.01 to 0.05 in. w.c. relative to adjacent areas at all times."
  citation: "ASHRAE 170-2013 Table 7-1"
  performancePlane
  reqRequired
  spaceSpec: "ph::Space"
  spaceTypeKey: "aiiRoom"
}

@ex-req-aii-pressure-c: PerformanceCriterion {
  requirementRef: @ex-req-aii-pressure
  pointSpec: "ph::Point"
  negativePressure
  minVal: -0.05
  maxVal: -0.01
  unit: "inH₂O"
  adherenceTarget: 99
  autoMode
}

// A prohibition: verification passes on ABSENCE of the prohibited
// condition. The matrix's "Exhausted" column is this requirement.
@ex-req-aii-recirc: Requirement {
  dis: "AII room air recirculation prohibited"
  docRef: @ex-opr
  reqId: "OPR-4.2.3"
  category: "iaq"
  oprHealthIeq
  narrative: "Air from airborne infection isolation rooms shall not be recirculated; AII room exhaust shall discharge directly outdoors."
  citation: "ASHRAE 170-2013 Table 7-1"
  conformancePlane
  reqRequired
  prohibition
  spaceSpec: "ph::Space"
  spaceTypeKey: "aiiRoom"
}

// ── Attestation-plane requirements — human signoff with evidence ─────────

@ex-req-training: Requirement {
  dis: "Operator training on BAS"
  docRef: @ex-opr
  reqId: "OPR-5.1.1"
  category: "om"
  narrative: "Facility operations staff shall receive a minimum of 8 hours of hands-on training on the building automation system prior to turnover."
  attestationPlane
  reqRequired
}

@ex-req-training-c: ProcessRequirement {
  requirementRef: @ex-req-training
  trainingDeliverable
  turnoverPhase
  facilityManagerRole
}

