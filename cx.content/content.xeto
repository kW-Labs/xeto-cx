  trainingPhase
  subjectRef: @ex-training-plan
  acceptanceAccepted
  recommendedAt: DateTime "2026-06-01T09:00:00-06:00 Denver"
  acceptedAt: DateTime "2026-06-03T14:00:00-06:00 Denver"
  attestationRef: @ex-accept-training-sig
}

@ex-accept-training-sig: Attestation {
  subjectRef: @ex-accept-training
  ownerRole
  userName: "Example Owner Rep"
  signedAt: DateTime "2026-06-03T14:00:00-06:00 Denver"
}

// ── Per-step test evidence (Guideline 0 section 7.2.10.1g) ───────────────

@ex-fpt-run: FptTest {
  dis: "AHU-1 FPT — first attempt"
  cxProjectRef: @ex-project
  siteRef: @ex-site
  scriptRef: @ex-ahu-fpt
