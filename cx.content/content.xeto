//
// Example FPT script — economizer functional test excerpt, linked back to
// the OPR heat-recovery requirement to demonstrate traceability.
//

@ex-ahu-fpt: TestScript {
  dis: "AHU Functional Performance Test — Economizer and Heat Recovery"
  fptPhase
  targetSpec: "ph::Ahu"
  version: "1.0"
}

@ex-fpt-s01: TestStepDef {
  scriptRef: @ex-ahu-fpt
  stepId: "s01"
  instruction: "Command outdoor air temperature input below economizer high limit. Verify economizer modulates open."
  expected: "OA damper modulates toward 100 percent; mechanical cooling holds off."
  sortOrder: 1
}

@ex-fpt-s02: TestStepDef {
  scriptRef: @ex-ahu-fpt
  stepId: "s02"
  instruction: "With unit in minimum outdoor air, verify heat recovery wheel is rotating and recovering exhaust energy."
  expected: "Wheel rotates; exhaust-side and supply-side temperature differentials consistent with recovery."
  sortOrder: 2
}

@ex-fpt-s03: TestStepDef {
  scriptRef: @ex-ahu-fpt
  stepId: "s03"
  instruction: "Restore all overrides and return unit to normal automatic operation."
  expected: "Unit returns to scheduled operation with no active alarms."
  sortOrder: 3
}

//
// Example sequence application — a published guideline sequence applied to
// the project AHU. The source is cited by section id (published prose is
// never embedded); the parameter records are the fill-in contract; the
// statement compiles into a requirement and an FPT step.
//

@ex-seq-g36: SequenceSource {
  dis: "ASHRAE Guideline 36-2024"
  publisher: "ASHRAE"
  docId: "G36-2024"
  edition: "2024"
}

@ex-seq-sat: SequenceSection {
  sourceRef: @ex-seq-g36
  sectionId: "5.16.2.2"
  title: "Supply air temperature setpoint reset"
  modeLogicSection
  stableAnchor
}

@ex-seq-sat-stmt: SequenceStatement {
  sectionRef: @ex-seq-sat
  requirementRef: @ex-req-sat-reset
  sortOrder: 1
}

@ex-req-sat-reset: Requirement {
  dis: "AHU supply air temperature reset"
  docRef: @ex-opr
  reqId: "OPR-3.3.1"
  category: "energy"
  oprEnergy
  narrative: "Air handling unit supply air temperature setpoint shall reset per the trim-and-respond logic of the cited guideline section, within the design minimum and maximum setpoint limits."
  citation: "ASHRAE G36-2024 section 5.16.2.2"
  attestationPlane
  reqRequired
  targetSpec: "ph::Ahu"
}

// Designer-scheduled setpoint limit — placeholder until the design supplies it
@ex-seq-param-maxsat: SequenceParam {
  sourceRef: @ex-seq-g36
  symbol: "Max_ClgSAT"
  dis: "Maximum cooling supply air temperature setpoint"
  definedIn: "3.1.4.1"
  designerRole
  setpointParam
  unit: "°F"
  placeholder
}

// TAB-measured pressure ceiling — field-determined per the source's procedure
@ex-seq-param-maxdsp: SequenceParam {
  sourceRef: @ex-seq-g36
  symbol: "Max_DSP"
  dis: "Maximum duct static pressure setpoint"
  definedIn: "3.2.1.1"
  tabRole
  tuningParam
  unit: "inH₂O"
  placeholder
  procedure: "Field-measured at design airflow per the source's TAB procedure"
}

@ex-seq-inst: SequenceInstance {
  dis: "AHU-1 supply air temperature reset"
  sourceRef: @ex-seq-g36
  cxProjectRef: @ex-project
  sectionRefs: { @ex-seq-sat }
  notes: "Applied to the example AHU; Max_DSP unresolved pending TAB"
}

@ex-seq-pv-maxsat: SequenceParamValue {
  instanceRef: @ex-seq-inst
  paramRef: @ex-seq-param-maxsat
  val: Number "65°F"
  designerRole
  resolvedAt: DateTime "2026-03-15T09:00:00-06:00 Denver"
}

// FPT step generated from the sequence statement, closing the loop from
// sequence atom to witnessed test
@ex-fpt-s04: TestStepDef {
  scriptRef: @ex-ahu-fpt
  stepId: "s04"
  instruction: "Generate cooling requests from multiple zones; observe supply air temperature setpoint response."
  expected: "Setpoint trims and responds within the configured minimum and maximum limits."
  requirementRefs: { @ex-req-sat-reset }
  sortOrder: 4
}

//
// EBCx continuation — the same building, after turnover. Demonstrates the
// 202 Foreword transitions (OPR -> CFR, Cx Plan -> OCx Plan), continuous
// verification results on all three outcomes, an owner-accepted variance
// (202 Appendix O), and the Systems Manual as an index of living records.
// The project record above is shown at its design-phase snapshot.
//

// ── OPR transitions to CFR; a failing requirement is amended ─────────────

@ex-cfr: Cfr {
  dis: "Example Facility CFR v1.0"
  siteRef: @ex-site
  version: "1.0"
  docSuperseded
  narrative: "Current facility requirements carried forward from the project OPR at turnover."
  sourceOprRefs: { @ex-opr }
}

@ex-cfr-2: Cfr {
  dis: "Example Facility CFR v1.1"
  siteRef: @ex-site
  version: "1.1"
  docPublished
  publishedAt: DateTime "2026-07-08T12:00:00-06:00 Denver"
  supersedesRef: @ex-cfr
  narrative: "Amended after owner accepted a seasonal space-temperature variance (see variance record)."
  sourceOprRefs: { @ex-opr }
}

// CFR v1.1 restates the space-temperature requirement at the amended
// adherence target; supersedesRef preserves lineage across the OPR->CFR
// transition.
@ex-req-space-temp-cfr: Requirement {
  dis: "Space temperature compliance (amended)"
  docRef: @ex-cfr-2
  reqId: "CFR-4.1.1"
  category: "comfort"
  narrative: "Occupied spaces shall maintain 70-74 degF during occupied hours at 90 percent adherence through 2026-09-30, returning to 95 percent thereafter."
  performancePlane
  reqRequired
  spaceSpec: "ph::Space"
  supersedesRef: @ex-req-space-temp
}

@ex-req-space-temp-cfr-c: PerformanceCriterion {
  requirementRef: @ex-req-space-temp-cfr
  pointSpec: "ph::Point"
  minVal: 70
  maxVal: 74
  unit: "°F"
  adherenceTarget: 90
  evalSpan: "occupied hours, 30day rolling"
  autoMode
}

// ── Ongoing commissioning program (202 section 3, "Ongoing Cx") ──────────

@ex-ocx-plan: CxPlan {
  dis: "Example Facility OCx Plan"
  siteRef: @ex-site
  cxProjectRef: @ex-project
  version: "1.0"
  docPublished
}

@ex-ocx: OcxProgram {
  dis: "Example Facility Ongoing Cx"
  siteRef: @ex-site
  cfrRef: @ex-cfr-2
  planRef: @ex-ocx-plan
  startedAt: Date "2026-07-01"
  reviewCadence: Cadence "quarterly"
}

// Facility change event — the OCx loop of Guideline 0 Figure B-1: a use
// change is evaluated against the CFR, dispositioned, and follow-on
// updates tracked to closure
@ex-change-tenant: FacilityChange {
  dis: "Second-floor tenant fit-out: open office to conference center"
  siteRef: @ex-site
  ocxProgramRef: @ex-ocx
  changeOfUse
  description: "Occupancy density triples in the affected zones; ventilation and cooling requirements re-evaluated against the CFR."
  occurredAt: Date "2026-07-10"
  evaluatedAt: Date "2026-07-15"
  changesOpr
  requirementRefs: { @ex-req-space-temp-cfr }
  systemsManualUpdated
}

// ── Verification results — one per outcome ───────────────────────────────

// Conformance check: heat-recovery marker present on every scoped AHU
@ex-vr-pass: VerificationResult {
  requirementRef: @ex-req-ahu-hr
  criterionRef: @ex-req-ahu-hr-c
  outcomePass
  conformancePlane
  autoMode
  ranAt: DateTime "2026-06-01T08:00:00-06:00 Denver"
  notes: "heatRecovery marker present on all AHU records in scope"
}

// Performance check: June adherence landed at 91% against the 95% target
@ex-vr-fail: VerificationResult {
  requirementRef: @ex-req-space-temp
  outcomeFail
  performancePlane
  autoMode
  ranAt: DateTime "2026-06-30T17:00:00-06:00 Denver"
  evalSpan: "2026-06-01..2026-06-30 occupied hours"
  adherencePct: 91
}

// Inconclusive: trend data gap — honestly not "pass" and not "fail"
@ex-vr-inconclusive: VerificationResult {
  requirementRef: @ex-req-space-temp
  outcomeInconclusive
  performancePlane
  autoMode
  ranAt: DateTime "2026-05-31T17:00:00-06:00 Denver"
  evalSpan: "2026-05-01..2026-05-31 occupied hours"
  notes: "Zone sensors offline 5/09-5/21; insufficient data to evaluate adherence"
}

// ── Failing result -> issue -> owner-accepted variance (202 App O) ───────

@ex-issue-adherence: CxIssue {
  dis: "June space-temp adherence 91% vs 95% required"
  cxProjectRef: @ex-project
  siteRef: @ex-site
  description: "West-zone afternoon solar load drives excursions above 74 degF; mitigation requires shade retrofit scheduled for Q4."
  analyticsFault
  priorityMedium
  issueClosed
  ballInCourt: CxParty "owner"
  requirementRef: @ex-req-space-temp
  sourceAnalytics
  sourceRef: @ex-vr-fail
}

@ex-variance-adherence: RequirementVariance {
  requirementRef: @ex-req-space-temp
  description: "Owner accepts 90 percent adherence for the 2026 cooling season pending Q4 shade retrofit."
  impacts: "Comfort: afternoon excursions to 76 degF in west zones. Energy: none. Health/safety: none."
  expiresAt: Date "2026-09-30"
  sourceIssueRef: @ex-issue-adherence
  attestationRef: @ex-variance-signoff
  acceptedAt: DateTime "2026-07-08T10:00:00-06:00 Denver"
}

@ex-variance-signoff: Attestation {
  subjectRef: @ex-variance-adherence
  ownerRole
  userName: "Example Owner Rep"
  signedAt: DateTime "2026-07-08T10:00:00-06:00 Denver"
  notes: "Variance accepted per 202 Appendix O(a); CFR updated to v1.1"
}

// ── Finding -> measure -> savings (EBCx master list of findings) ─────────
// The issue above is the finding; the measure carries the solution and its
// economics; savings records harden from estimated toward verified.

@ex-measure-shade: CxMeasure {
  dis: "West-zone exterior shade retrofit"
  cxProjectRef: @ex-project
  siteRef: @ex-site
  findingRef: @ex-issue-adherence
  description: "Install exterior shading on west-facing glazing to eliminate afternoon solar-driven temperature excursions."
  capitalMeasure
  sowMedium
  measureApproved
  costEst: 42000
  paybackYears: 8.5
  ownerPriority: 1
  benefits: "Restores 95 percent comfort adherence; reduces peak cooling load."
  risks: "Facade permit review may extend schedule past Q4."
}

@ex-measure-shade-sav: SavingsEstimate {
  measureRef: @ex-measure-shade
  elecSavings
  estimatedBasis
  annualQty: 31000
  qtyUnit: "kWh"
  annualCost: 4900
  method: "hourly simulation of west-zone cooling load with and without shading"
  estimatedAt: Date "2026-07-05"
}

// ── Training delivered and formally accepted ─────────────────────────────

@ex-training-plan: TrainingPlan {
