// Typed index rows — which record serves which of the six parts shared by
// 202 section 14.2.3 and Guideline 1.4 section 4.3.2
@ex-sm-e1: SystemsManualEntry {
  systemsManualRef: @ex-sysman
  docRef: @ex-cfr-2
  smDesignConstruction
}

@ex-sm-e2: SystemsManualEntry {
  systemsManualRef: @ex-sysman
  docRef: @ex-facility-guide
  smFacilityOps
